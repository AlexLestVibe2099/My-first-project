# Supabase — публичные ключи (префикс VITE_ обязателен для доступа из браузера)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Секретный ключ сервера — НИКОГДА не добавлять в .env и не использовать в браузере!
# Задаётся только через Supabase Dashboard → Settings → Edge Functions → Secrets
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
