# Supabase — публичные ключи (префикс VITE_ обязателен для доступа из браузера)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Серверные секреты используются только Supabase Edge Function (не фронтендом).
# Для продакшена задавай их в Supabase Dashboard → Edge Functions → Secrets.

# UniSender интеграция (используется сервером / Edge Function, не фронтендом)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
UNISENDER_API_KEY=your-unisender-api-key
UNISENDER_SENDER_EMAIL=no-reply@your-domain.com
UNISENDER_SENDER_NAME=CycleCare
UNISENDER_WELCOME_SUBJECT=Регистрация в CycleCare завершена

# Подпись входящих webhook-запросов (HMAC SHA-256)
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret

# Фолбэк для Supabase Database Webhooks (если нет возможности подписывать тело)
WEBHOOK_SHARED_TOKEN=your-static-webhook-token

# AI-ассистент (Supabase Edge Function -> OpenAI)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# CORS allowlist для Edge Functions (через запятую)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-domain.com

# Тестовый аккаунт для Playwright e2e
E2E_AUTH_EMAIL=qa@example.com
E2E_AUTH_PASSWORD=change-me

# Пароль для smoke-check скрипта (не боевой)
SUPABASE_SMOKE_TEST_PASSWORD=change-me
